{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "happy path - loan approved automatically, customer accepts",
      "description": "Loan application with good credit score. DMN auto-approves (creditScore 780, low amount). Customer accepts. Loan provided.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "Process_1f255lo"
          },
          "variables": {
            "applicantName": "Alice Smith",
            "loan": {
              "amount": 10000,
              "tenure": 36
            },
            "pi": {
              "annual_salary": 50000
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_0jg58ef"
          },
          "variables": {
            "creditScore": 780
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_19tmw4x"
          },
          "variables": {
            "ticketId": 1001
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": {
            "processDefinitionId": "Process_1f255lo"
          },
          "elementSelectors": [
            {
              "elementId": "Activity_0ff69jm"
            }
          ],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_0ff69jm"
          },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_1qx00c8"
          },
          "variables": {}
        },
        {
          "type": "PUBLISH_MESSAGE",
          "name": "customer_accepts_offer",
          "correlationKey": "1001",
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_0neec1e"
          },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_0ii025u"
          },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "Process_1f255lo"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
