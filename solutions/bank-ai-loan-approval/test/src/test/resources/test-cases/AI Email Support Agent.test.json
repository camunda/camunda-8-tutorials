{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "happy path - agent resolves successfully, case solved",
      "description": "Customer email received. Past conversations fetched. Agent handles request. Agent-as-a-Judge rates AGENT_SUCCESS. Final answer sent. Human reviews. Case solved.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "Process_0j5qzil" },
          "startInstructions": [{ "type": "START_BEFORE_ELEMENT", "elementId": "Activity_0kce977" }],
          "variables": {
            "currentEmail": {
              "subject": "Question about my loan application",
              "body": "What is the current status of my loan application?",
              "from": "customer@example.com"
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_0kce977" },
          "variables": {
            "pastConversations": [
              { "date": "2024-01-01", "summary": "Customer inquired about rates" }
            ]
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": { "jobType": "io.camunda.agenticai:aiagent-job-worker:1" },
          "variables": {
            "agent": {
              "responseText": "Your loan application is under review. You will receive an update within 2 business days.",
              "context": {
                "state": "READY",
                "metrics": { "modelCalls": 1, "tokenUsage": { "inputTokenCount": 100, "outputTokenCount": 50 } },
                "conversation": {
                  "type": "in-process",
                  "messages": [
                    { "role": "user", "content": [{ "type": "text", "text": "What is the current status of my loan application?" }] },
                    { "role": "assistant", "content": [{ "type": "text", "text": "Your loan application is under review." }] }
                  ]
                }
              }
            }
          },
          "completionConditionFulfilled": true
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_0tn95r9" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_0hp732o" },
          "variables": {
            "decision": "AGENT_SUCCESS",
            "reasoning": "Agent answered the question accurately within scope.",
            "reasoning_quality": "Clear and concise.",
            "identified_issues": "None",
            "customer_email": "Your loan application is under review."
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_0d9av47" },
          "variables": {}
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": { "elementId": "Activity_1647ldd" },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "Process_0j5qzil" },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "agent suboptimal - manual finalization required",
      "description": "Agent-as-a-Judge rates AGENT_SUBOPTIMAL. Case sent to Finalize case manually user task. Human finalizes.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "Process_0j5qzil" },
          "startInstructions": [{ "type": "START_BEFORE_ELEMENT", "elementId": "Activity_0kce977" }],
          "variables": {
            "currentEmail": {
              "subject": "Loan rate inquiry",
              "body": "What interest rate will I get on a 10-year loan?",
              "from": "customer2@example.com"
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_0kce977" },
          "variables": { "pastConversations": [] }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": { "jobType": "io.camunda.agenticai:aiagent-job-worker:1" },
          "variables": {
            "agent": {
              "responseText": "Interest rates vary. Please contact your branch for exact rates.",
              "context": {
                "state": "READY",
                "metrics": { "modelCalls": 1, "tokenUsage": { "inputTokenCount": 80, "outputTokenCount": 30 } },
                "conversation": {
                  "type": "in-process",
                  "messages": [
                    { "role": "user", "content": [{ "type": "text", "text": "What interest rate will I get?" }] },
                    { "role": "assistant", "content": [{ "type": "text", "text": "Interest rates vary." }] }
                  ]
                }
              }
            }
          },
          "completionConditionFulfilled": true
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_0tn95r9" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_0hp732o" },
          "variables": {
            "decision": "AGENT_SUBOPTIMAL",
            "reasoning": "Agent gave a vague answer without using available rate tools.",
            "reasoning_quality": "Superficial reasoning.",
            "identified_issues": "Did not consult rate lookup tool.",
            "customer_email": ""
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "Process_0j5qzil" },
          "elementSelectors": [{ "elementId": "Activity_132636m" }],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": { "elementId": "Activity_132636m" },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "Process_0j5qzil" },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "no past conversations found - agent runs, case reviewed",
      "description": "Fetch past conversations raises error (no history). Process continues to agent. Agent succeeds. Case solved.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "Process_0j5qzil" },
          "startInstructions": [{ "type": "START_BEFORE_ELEMENT", "elementId": "Activity_0kce977" }],
          "variables": {
            "currentEmail": {
              "subject": "New customer loan application",
              "body": "I would like to apply for a mortgage loan.",
              "from": "newcustomer@example.com"
            }
          }
        },
        {
          "type": "THROW_BPMN_ERROR_FROM_JOB",
          "jobSelector": { "elementId": "Activity_0kce977" },
          "errorCode": "index_not_found",
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": { "jobType": "io.camunda.agenticai:aiagent-job-worker:1" },
          "variables": {
            "agent": {
              "responseText": "Welcome! I can help you start a mortgage loan application. Please provide your details.",
              "context": {
                "state": "READY",
                "metrics": { "modelCalls": 1, "tokenUsage": { "inputTokenCount": 90, "outputTokenCount": 45 } },
                "conversation": {
                  "type": "in-process",
                  "messages": [
                    { "role": "user", "content": [{ "type": "text", "text": "I would like to apply for a mortgage loan." }] },
                    { "role": "assistant", "content": [{ "type": "text", "text": "Welcome! I can help you start a mortgage loan application." }] }
                  ]
                }
              }
            }
          },
          "completionConditionFulfilled": true
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_0tn95r9" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_0hp732o" },
          "variables": {
            "decision": "AGENT_SUCCESS",
            "reasoning": "Agent appropriately welcomed new customer and initiated loan application guidance.",
            "reasoning_quality": "Good scope adherence.",
            "identified_issues": "None",
            "customer_email": "Welcome! Please provide your details to start your mortgage application."
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_0d9av47" },
          "variables": {}
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": { "elementId": "Activity_1647ldd" },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "Process_0j5qzil" },
          "state": "IS_COMPLETED"
        }
      ]
    }
  ],
  "_integrationTestNotes": "Integration tests should verify: (1) Activity_0kce977 (Fetch past conversations) retrieves real conversation history from the long-term memory store; (2) Activity_04glkkx adHocSubProcess invokes real AWS Bedrock AI agent via aiagent-job-worker connector; (3) Activity_0hp732o (Agent as a Judge) calls real Bedrock LLM to evaluate agent performance; (4) Activity_0d9av47 (Final answer) sends real email to customer via email connector; (5) Activity_0tn95r9 (Save customer interaction) persists conversation to real memory store."
}
