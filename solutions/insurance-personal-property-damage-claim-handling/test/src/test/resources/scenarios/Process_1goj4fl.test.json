{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "happy path - claim approved automatically",
      "description": "Receipt analyzed, damage identified, ticket created, customer data retrieved. DMN auto-approves small claim with full policy and zero prior claims. Approval email sent. Banking info received. Payment triggered.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "Process_1goj4fl"
          },
          "variables": {
            "claimId": "CLM001",
            "customerId": "CUST001",
            "claimedAmount": 150.0
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_0mmcuzy"
          },
          "variables": {
            "receipt_details": {
              "date_of_purchase": "2024-01-01",
              "price_at_purchase": 150.0
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_17krtpn"
          },
          "variables": {
            "identified_damage": {
              "item": "tv",
              "damage": "minor"
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_1vdz63b"
          },
          "variables": {
            "ticketId": 101
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_0etxz4e"
          },
          "variables": {
            "customer_claim_frequency_last_three_years": 0,
            "policy": "full"
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_0poax8d"
          },
          "variables": {}
        },
        {
          "type": "PUBLISH_MESSAGE",
          "name": "banking_info_received",
          "correlationKey": "101",
          "variables": {
            "bankingInfo": {
              "iban": "DE89370400440532013000"
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_0ankyj2"
          },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "Process_1goj4fl"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
