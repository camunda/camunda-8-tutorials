{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "happy path - expense approved by manager and finance",
      "description": "Employee creates expense report. Manager approves, finance approves. Expenses reimbursed (plain task, auto-executes).",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "Process_ExpenseReimbursement-0yibie4"
          },
          "variables": {
            "employeeId": "EMP001",
            "totalAmount": 250.0,
            "supervisorEmail": "supervisor@example.com"
          }
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "Activity_CreateExpenseReport"
          },
          "variables": {
            "expenses": [
              {
                "description": "Hotel",
                "amount": 200.0
              },
              {
                "description": "Meals",
                "amount": 50.0
              }
            ]
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": {
            "processDefinitionId": "Process_ExpenseReimbursement-0yibie4"
          },
          "elementSelectors": [
            {
              "elementId": "Activity_ReviewExpenseReport_Manager"
            }
          ],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "Activity_ReviewExpenseReport_Manager"
          },
          "variables": {
            "reviewOutcome": "approved"
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": {
            "processDefinitionId": "Process_ExpenseReimbursement-0yibie4"
          },
          "elementSelectors": [
            {
              "elementId": "Activity_ReviewExpenseReport_Finance"
            }
          ],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "Activity_ReviewExpenseReport_Finance"
          },
          "variables": {
            "reviewOutcome": "approved"
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "Process_ExpenseReimbursement-0yibie4"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "manager rejects expense report",
      "description": "Manager rejects the expense report. Rejection notification sent (plain task, auto-executes). Process ends.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "Process_ExpenseReimbursement-0yibie4"
          },
          "variables": {
            "employeeId": "EMP002",
            "totalAmount": 5000.0,
            "supervisorEmail": "supervisor@example.com"
          }
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "Activity_CreateExpenseReport"
          },
          "variables": {
            "expenses": [
              {
                "description": "Flight",
                "amount": 5000.0
              }
            ]
          }
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "Activity_ReviewExpenseReport_Manager"
          },
          "variables": {
            "reviewOutcome": "rejected"
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "Process_ExpenseReimbursement-0yibie4"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "finance rejects expense report after manager approval",
      "description": "Manager approves but finance rejects. Rejection notification sent (plain task, auto-executes). Process ends.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "Process_ExpenseReimbursement-0yibie4"
          },
          "variables": {
            "employeeId": "EMP003",
            "totalAmount": 1500.0,
            "supervisorEmail": "supervisor@example.com"
          }
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "Activity_CreateExpenseReport"
          },
          "variables": {
            "expenses": [
              {
                "description": "Conference",
                "amount": 1500.0
              }
            ]
          }
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "Activity_ReviewExpenseReport_Manager"
          },
          "variables": {
            "reviewOutcome": "approved"
          }
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "Activity_ReviewExpenseReport_Finance"
          },
          "variables": {
            "reviewOutcome": "rejected"
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
