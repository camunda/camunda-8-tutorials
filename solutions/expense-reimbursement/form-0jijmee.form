{
  "components": [
    {
      "text": "# Expense Claim",
      "type": "text",
      "layout": {
        "row": "Row_0b02kr1",
        "columns": null
      },
      "id": "Field_1gbvbm7"
    },
    {
      "text": "### Personal Information\n\nPlease provide your personal information to ensure proper assignment of the expense claim.",
      "type": "text",
      "layout": {
        "row": "Row_1ef2qla",
        "columns": null
      },
      "id": "Field_1sbsc67",
      "conditional": {
        "hide": "=isReview"
      }
    },
    {
      "label": "First name",
      "type": "textfield",
      "layout": {
        "row": "Row_11isqe5",
        "columns": null
      },
      "id": "Field_0zyjfuh",
      "key": "firstName",
      "validate": {
        "required": false
      }
    },
    {
      "label": "Last name",
      "type": "textfield",
      "layout": {
        "row": "Row_11isqe5",
        "columns": null
      },
      "id": "Field_0m4s208",
      "key": "lastName",
      "validate": {
        "required": false
      }
    },
    {
      "label": "Email",
      "type": "textfield",
      "layout": {
        "row": "Row_0f1wn8t",
        "columns": null
      },
      "id": "Field_02tkefw",
      "key": "email",
      "appearance": {
        "prefixAdorner": "@"
      },
      "validate": {
        "validationType": "email",
        "required": true
      }
    },
    {
      "values": [
        {
          "label": "IT",
          "value": "IT"
        },
        {
          "label": "Product",
          "value": "product"
        },
        {
          "label": "Finance",
          "value": "finance"
        },
        {
          "label": "Accounting",
          "value": "accounting"
        },
        {
          "label": "Marketing",
          "value": "marketing"
        }
      ],
      "label": "Department",
      "type": "select",
      "layout": {
        "row": "Row_0f1wn8t",
        "columns": null
      },
      "id": "Field_07rt8k5",
      "key": "department",
      "searchable": true
    },
    {
      "text": "### Supervisor\n\nPlease provide the email of your supervisor to review the expense.",
      "type": "text",
      "layout": {
        "row": "Row_1ybnh5e",
        "columns": null
      },
      "id": "Field_0kq8635"
    },
    {
      "label": "Supervisor email",
      "type": "textfield",
      "layout": {
        "row": "Row_0lcbkut",
        "columns": 8
      },
      "id": "Field_05eprbr",
      "key": "supervisorEmail",
      "appearance": {
        "prefixAdorner": "@"
      },
      "conditional": {
        "hide": "=isReview"
      }
    },
    {
      "text": "## Expense Details",
      "type": "text",
      "layout": {
        "row": "Row_0jzv103",
        "columns": null
      },
      "id": "Field_0rozem8"
    },
    {
      "subtype": "date",
      "dateLabel": "Expense date",
      "label": "Date time",
      "type": "datetime",
      "layout": {
        "row": "Row_1orcvpn",
        "columns": null
      },
      "id": "Field_0z4pwh0",
      "key": "expenseDate",
      "validate": {
        "required": true
      }
    },
    {
      "values": [
        {
          "label": "Custom",
          "value": "custom"
        },
        {
          "label": "Travel",
          "value": "travel"
        }
      ],
      "label": "Expense type",
      "type": "select",
      "layout": {
        "row": "Row_1orcvpn",
        "columns": null
      },
      "id": "Field_1eiqop0",
      "key": "expenseType",
      "searchable": true
    },
    {
      "subtype": "date",
      "dateLabel": "Travel start",
      "label": "Date time",
      "type": "datetime",
      "layout": {
        "row": "Row_010wbhw",
        "columns": null
      },
      "id": "Field_17w0xsu",
      "key": "travelStart",
      "conditional": {
        "hide": "=not(expenseType = \"travel\")"
      },
      "description": "Enter the start and end date of your travel"
    },
    {
      "subtype": "date",
      "dateLabel": "Travel end",
      "label": "Date time",
      "type": "datetime",
      "layout": {
        "row": "Row_010wbhw",
        "columns": null
      },
      "id": "Field_1ttfo0c",
      "key": "travelEnd",
      "conditional": {
        "hide": "=not(expenseType = \"travel\")"
      }
    },
    {
      "text": "\u26a0\ufe0f The end date must be after the start date.",
      "type": "text",
      "layout": {
        "row": "Row_1hua3bm",
        "columns": null
      },
      "id": "Field_15j8ot1",
      "conditional": {
        "hide": "=travelEnd = null or not(after(travelStart, travelEnd))"
      }
    },
    {
      "label": "Travel location",
      "type": "textfield",
      "layout": {
        "row": "Row_00kdr2a",
        "columns": null
      },
      "id": "Field_1xz2kcy",
      "key": "travelLocation",
      "appearance": {
        "prefixAdorner": "\ud83d\udccd"
      },
      "conditional": {
        "hide": "=not(expenseType = \"travel\")"
      }
    },
    {
      "label": "Custom expense type",
      "type": "textfield",
      "layout": {
        "row": "Row_1tqe6ut",
        "columns": null
      },
      "id": "Field_03ow051",
      "key": "customExpenseType",
      "conditional": {
        "hide": "=not(expenseType = \"custom\")"
      }
    },
    {
      "label": "Expense purpose",
      "type": "textarea",
      "layout": {
        "row": "Row_0ar8roa",
        "columns": null
      },
      "id": "Field_136skvr",
      "key": "expensePurpose",
      "validate": {
        "required": false
      },
      "description": "Describe the purpose of your expense. A good description increases the likelihood of quick approval."
    },
    {
      "label": "Expense amount",
      "type": "number",
      "layout": {
        "row": "Row_0jjom6t",
        "columns": 8
      },
      "id": "Field_189ka5c",
      "key": "expenseAmount",
      "appearance": {
        "prefixAdorner": "USD"
      },
      "validate": {
        "required": true
      },
      "decimalDigits": 2,
      "increment": "0.5"
    }
  ],
  "type": "default",
  "id": "Form_ExpenseClaim",
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.2.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.12.0-rc.0"
  },
  "schemaVersion": 9
}