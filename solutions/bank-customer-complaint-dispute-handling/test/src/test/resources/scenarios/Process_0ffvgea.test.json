{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "high confidence fraud detected - automatic no refund",
      "description": "Low claim frequencies + large amount → DMN returns isHighFraudRatingConfidence=true, isRefund=false. Sub-process ends normally. Customer informed (no refund).",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "Process_0ffvgea"
          },
          "variables": {
            "customerId": "CUST001",
            "complaintType": "unauthorized_transaction",
            "disputeDetails": {
              "disputeId": "D001",
              "disputeAmount": {
                "amount": 500,
                "currency": "EUR"
              },
              "disputeStartDate": "2024-08-07T10:00:00Z"
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_0f196ti"
          },
          "variables": {}
        },
        {
          "type": "PUBLISH_MESSAGE",
          "name": "dispute_process_receive_documents",
          "correlationKey": "D001CUST001",
          "variables": {
            "documentsReceived": true
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_1nvtpnt"
          },
          "variables": {
            "customerInfo": {
              "name": "Alice",
              "email": "alice@example.com"
            },
            "customer_claim_frequency": 2
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_1ec0e8t"
          },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_1ys0vez"
          },
          "variables": {
            "vendorInfo": {
              "name": "Vendor A"
            },
            "vendor_claim_frequency": 3
          }
        },
        {
          "type": "PUBLISH_MESSAGE",
          "name": "dispute_process_refund_approved",
          "correlationKey": "D001",
          "variables": {}
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": {
            "processDefinitionId": "Process_0ffvgea"
          },
          "elementSelectors": [
            {
              "elementId": "Activity_0maynr7"
            }
          ],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "Activity_0maynr7"
          },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "Process_0ffvgea"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
