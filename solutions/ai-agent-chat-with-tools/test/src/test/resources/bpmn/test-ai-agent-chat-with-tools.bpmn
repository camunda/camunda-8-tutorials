<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  id="test-ai-agent-chat-with-tools-definitions"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <!--
    Connector isolation test process for ai-agent-chat-with-tools.

    Structure: one start event → exclusive gateway → one branch per HTTP tool → end event.
    Tests activate a single tool using startBeforeElement("<ToolElementId>"), which
    bypasses the gateway entirely — the gateway exists only for BPMN validity and
    to make the diagram readable in Camunda Modeler.

    Usage in AgentJavaIT:
      client.newCreateInstanceCommand()
        .bpmnProcessId("test-ai-agent-chat-with-tools")
        .latestVersion()
        .startBeforeElement("ListUsers")
        .send().join();

    Connector config is identical to the AHSP tool elements, with fromAi() expressions
    replaced by direct process variable references.

    Keep this file in sync with the AHSP in ai-agent-chat-with-tools.bpmn.
    When tools are added, removed, or reconfigured in the AHSP, update here too.

    HTTP tools: ListUsers, LoadUserByID, Search_Recipe, Jokes_API, Fetch_URL
    Not included: script tasks (GetDateAndTime, SuperfluxCalculation, SendEmail) and
    user tasks (Human_Send_Email_Request) — those are covered by E2E tests.
  -->
  <bpmn:process id="test-ai-agent-chat-with-tools" name="Test: AI Agent Chat With Tools — Connector Isolation" isExecutable="true">

    <bpmn:startEvent id="Start" name="Select Tool">
      <bpmn:outgoing>Flow_Start_Gateway</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_SelectTool" name="Which tool?">
      <bpmn:incoming>Flow_Start_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Gateway_ListUsers</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_LoadUserByID</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_SearchRecipe</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_JokesAPI</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_FetchURL</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_Start_Gateway" sourceRef="Start" targetRef="Gateway_SelectTool" />

    <!-- ===== Branch 1: ListUsers ===== -->
    <bpmn:sequenceFlow id="Flow_Gateway_ListUsers" sourceRef="Gateway_SelectTool" targetRef="ListUsers">
      <bpmn:conditionExpression>=connectorTest = "ListUsers"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="ListUsers" name="List Users">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="https://jsonplaceholder.typicode.com/users" target="url" />
          <zeebe:input source="false" target="storeResponse" />
          <zeebe:input source="20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="20" target="readTimeoutInSeconds" />
          <zeebe:input source="false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultExpression" value="={toolCallResult: for user in response.body return {id: user.id, name: user.name, username: user.username}}" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_ListUsers</bpmn:incoming>
      <bpmn:outgoing>Flow_ListUsers_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_ListUsers">
      <bpmn:incoming>Flow_ListUsers_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ListUsers_End" sourceRef="ListUsers" targetRef="End_ListUsers" />

    <!-- ===== Branch 2: LoadUserByID — input: userId (integer) ===== -->
    <bpmn:sequenceFlow id="Flow_Gateway_LoadUserByID" sourceRef="Gateway_SelectTool" targetRef="LoadUserByID">
      <bpmn:conditionExpression>=connectorTest = "LoadUserByID"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="LoadUserByID" name="Load User By ID">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&quot;https://jsonplaceholder.typicode.com/users/&quot; + string(userId)" target="url" />
          <zeebe:input source="false" target="storeResponse" />
          <zeebe:input source="20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="20" target="readTimeoutInSeconds" />
          <zeebe:input source="false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultExpression" value="={toolCallResult: if (is defined(response.body.id)) then response.body else &quot;User not found&quot;}" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_LoadUserByID</bpmn:incoming>
      <bpmn:outgoing>Flow_LoadUserByID_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_LoadUserByID">
      <bpmn:incoming>Flow_LoadUserByID_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_LoadUserByID_End" sourceRef="LoadUserByID" targetRef="End_LoadUserByID" />

    <!-- ===== Branch 3: Search_Recipe — input: searchQuery (string) ===== -->
    <bpmn:sequenceFlow id="Flow_Gateway_SearchRecipe" sourceRef="Gateway_SelectTool" targetRef="Search_Recipe">
      <bpmn:conditionExpression>=connectorTest = "Search_Recipe"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Search_Recipe" name="Search Recipe">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="https://dummyjson.com/recipes/search" target="url" />
          <zeebe:input source="={q: searchQuery}" target="queryParameters" />
          <zeebe:input source="false" target="storeResponse" />
          <zeebe:input source="20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="20" target="readTimeoutInSeconds" />
          <zeebe:input source="false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultExpression" value="={toolCallResult: if (count(response.body.recipes) &gt; 0) then response.body.recipes else &quot;No result found.&quot;}" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_SearchRecipe</bpmn:incoming>
      <bpmn:outgoing>Flow_SearchRecipe_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_SearchRecipe">
      <bpmn:incoming>Flow_SearchRecipe_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_SearchRecipe_End" sourceRef="Search_Recipe" targetRef="End_SearchRecipe" />

    <!-- ===== Branch 4: Jokes_API — no input required ===== -->
    <bpmn:sequenceFlow id="Flow_Gateway_JokesAPI" sourceRef="Gateway_SelectTool" targetRef="Jokes_API">
      <bpmn:conditionExpression>=connectorTest = "Jokes_API"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Jokes_API" name="Jokes API">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="https://v2.jokeapi.dev/joke/Any?format=txt&amp;safe-mode" target="url" />
          <zeebe:input source="false" target="storeResponse" />
          <zeebe:input source="20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="20" target="readTimeoutInSeconds" />
          <zeebe:input source="false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultExpression" value="={toolCallResult: response.body}" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_JokesAPI</bpmn:incoming>
      <bpmn:outgoing>Flow_JokesAPI_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_JokesAPI">
      <bpmn:incoming>Flow_JokesAPI_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_JokesAPI_End" sourceRef="Jokes_API" targetRef="End_JokesAPI" />

    <!-- ===== Branch 5: Fetch_URL — input: fetchUrl (string) ===== -->
    <bpmn:sequenceFlow id="Flow_Gateway_FetchURL" sourceRef="Gateway_SelectTool" targetRef="Fetch_URL">
      <bpmn:conditionExpression>=connectorTest = "Fetch_URL"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Fetch_URL" name="Fetch URL">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=fetchUrl" target="url" />
          <zeebe:input source="true" target="storeResponse" />
          <zeebe:input source="20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="20" target="readTimeoutInSeconds" />
          <zeebe:input source="false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultExpression" value="={toolCallResult: response.document}" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_FetchURL</bpmn:incoming>
      <bpmn:outgoing>Flow_FetchURL_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_FetchURL">
      <bpmn:incoming>Flow_FetchURL_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_FetchURL_End" sourceRef="Fetch_URL" targetRef="End_FetchURL" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="test-ai-agent-chat-with-tools">

      <!-- Start event (center y=320, vertically centered across 5 rows) -->
      <bpmndi:BPMNShape id="Start_di" bpmnElement="Start">
        <dc:Bounds x="152" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="145" y="345" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Gateway (center x=275, center y=320) -->
      <bpmndi:BPMNShape id="Gateway_SelectTool_di" bpmnElement="Gateway_SelectTool" isMarkerVisible="true">
        <dc:Bounds x="250" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="245" y="352" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_Gateway_di" bpmnElement="Flow_Start_Gateway">
        <di:waypoint x="188" y="320" />
        <di:waypoint x="250" y="320" />
      </bpmndi:BPMNEdge>

      <!-- Row 1: ListUsers (center y=80) -->
      <bpmndi:BPMNShape id="ListUsers_di" bpmnElement="ListUsers">
        <dc:Bounds x="380" y="40" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_ListUsers_di" bpmnElement="End_ListUsers">
        <dc:Bounds x="532" y="62" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Gateway_ListUsers_di" bpmnElement="Flow_Gateway_ListUsers">
        <di:waypoint x="275" y="295" />
        <di:waypoint x="275" y="80" />
        <di:waypoint x="380" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ListUsers_End_di" bpmnElement="Flow_ListUsers_End">
        <di:waypoint x="480" y="80" />
        <di:waypoint x="532" y="80" />
      </bpmndi:BPMNEdge>

      <!-- Row 2: LoadUserByID (center y=200) -->
      <bpmndi:BPMNShape id="LoadUserByID_di" bpmnElement="LoadUserByID">
        <dc:Bounds x="380" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_LoadUserByID_di" bpmnElement="End_LoadUserByID">
        <dc:Bounds x="532" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Gateway_LoadUserByID_di" bpmnElement="Flow_Gateway_LoadUserByID">
        <di:waypoint x="275" y="295" />
        <di:waypoint x="275" y="200" />
        <di:waypoint x="380" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LoadUserByID_End_di" bpmnElement="Flow_LoadUserByID_End">
        <di:waypoint x="480" y="200" />
        <di:waypoint x="532" y="200" />
      </bpmndi:BPMNEdge>

      <!-- Row 3: Search_Recipe (center y=320, same as gateway) -->
      <bpmndi:BPMNShape id="Search_Recipe_di" bpmnElement="Search_Recipe">
        <dc:Bounds x="380" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_SearchRecipe_di" bpmnElement="End_SearchRecipe">
        <dc:Bounds x="532" y="302" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Gateway_SearchRecipe_di" bpmnElement="Flow_Gateway_SearchRecipe">
        <di:waypoint x="300" y="320" />
        <di:waypoint x="380" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SearchRecipe_End_di" bpmnElement="Flow_SearchRecipe_End">
        <di:waypoint x="480" y="320" />
        <di:waypoint x="532" y="320" />
      </bpmndi:BPMNEdge>

      <!-- Row 4: Jokes_API (center y=440) -->
      <bpmndi:BPMNShape id="Jokes_API_di" bpmnElement="Jokes_API">
        <dc:Bounds x="380" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_JokesAPI_di" bpmnElement="End_JokesAPI">
        <dc:Bounds x="532" y="422" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Gateway_JokesAPI_di" bpmnElement="Flow_Gateway_JokesAPI">
        <di:waypoint x="275" y="345" />
        <di:waypoint x="275" y="440" />
        <di:waypoint x="380" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_JokesAPI_End_di" bpmnElement="Flow_JokesAPI_End">
        <di:waypoint x="480" y="440" />
        <di:waypoint x="532" y="440" />
      </bpmndi:BPMNEdge>

      <!-- Row 5: Fetch_URL (center y=560) -->
      <bpmndi:BPMNShape id="Fetch_URL_di" bpmnElement="Fetch_URL">
        <dc:Bounds x="380" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_FetchURL_di" bpmnElement="End_FetchURL">
        <dc:Bounds x="532" y="542" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Gateway_FetchURL_di" bpmnElement="Flow_Gateway_FetchURL">
        <di:waypoint x="275" y="345" />
        <di:waypoint x="275" y="560" />
        <di:waypoint x="380" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FetchURL_End_di" bpmnElement="Flow_FetchURL_End">
        <di:waypoint x="480" y="560" />
        <di:waypoint x="532" y="560" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
