{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "Happy path — user satisfied on first response (no tool calls)",
      "description": "The AI agent responds directly without calling any tools. The user is satisfied on the first response and the process completes. Tests outer-flow gateway routing on the happy path.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "variables": {
            "inputText": "What is the capital of France?"
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": {
            "jobType": "io.camunda.agenticai:aiagent-job-worker:1"
          },
          "variables": {
            "agent": {
              "context": {
                "state": "READY",
                "metrics": {
                  "modelCalls": 1,
                  "tokenUsage": {"inputTokenCount": 400, "outputTokenCount": 80}
                },
                "conversation": {
                  "type": "in-process",
                  "messages": [
                    {
                      "role": "user",
                      "content": [{"type": "text", "text": "What is the capital of France?"}]
                    },
                    {
                      "role": "assistant",
                      "content": [{"type": "text", "text": "The capital of France is Paris."}]
                    }
                  ]
                }
              },
              "responseText": "The capital of France is Paris."
            }
          },
          "completionConditionFulfilled": true
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "elementSelectors": [
            {"elementId": "User_Feedback"}
          ],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "User_Feedback"
          },
          "variables": {
            "userSatisfied": true
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "elementSelectors": [
            {"elementId": "StartEvent_1"},
            {"elementId": "AI_Agent"},
            {"elementId": "User_Feedback"},
            {"elementId": "Event_0i39jej"}
          ],
          "state": "IS_COMPLETED_IN_ORDER"
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "Loop path — user not satisfied, then satisfied on second try",
      "description": "User answers 'not satisfied' after the first agent response. The process loops back through the gateway and the AHSP runs again. User is satisfied on the second response. Tests the loop gateway branch.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "variables": {
            "inputText": "List all available users for me."
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": {
            "jobType": "io.camunda.agenticai:aiagent-job-worker:1"
          },
          "variables": {
            "agent": {
              "context": {
                "state": "READY",
                "metrics": {
                  "modelCalls": 1,
                  "tokenUsage": {"inputTokenCount": 500, "outputTokenCount": 80}
                },
                "conversation": {
                  "type": "in-process",
                  "messages": [
                    {
                      "role": "user",
                      "content": [{"type": "text", "text": "List all available users for me."}]
                    },
                    {
                      "role": "assistant",
                      "content": [{"type": "text", "text": "Here are the available users with their usernames."}]
                    }
                  ]
                }
              },
              "responseText": "Here are the available users with their usernames."
            }
          },
          "completionConditionFulfilled": true
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "elementSelectors": [
            {"elementId": "User_Feedback"}
          ],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "User_Feedback"
          },
          "variables": {
            "userSatisfied": false,
            "followUpInput": "Please also show me the email of each user."
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": {
            "jobType": "io.camunda.agenticai:aiagent-job-worker:1"
          },
          "variables": {
            "agent": {
              "context": {
                "state": "READY",
                "metrics": {
                  "modelCalls": 2,
                  "tokenUsage": {"inputTokenCount": 900, "outputTokenCount": 150}
                },
                "conversation": {
                  "type": "in-process",
                  "messages": [
                    {
                      "role": "user",
                      "content": [{"type": "text", "text": "Please also show me the email of each user."}]
                    },
                    {
                      "role": "assistant",
                      "content": [{"type": "text", "text": "Here are the users with their email addresses."}]
                    }
                  ]
                }
              },
              "responseText": "Here are the users with their email addresses."
            }
          },
          "completionConditionFulfilled": true
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "elementSelectors": [
            {"elementId": "User_Feedback"}
          ],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "User_Feedback"
          },
          "variables": {
            "userSatisfied": true
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "ListUsers tool — agent calls ListUsers then responds",
      "description": "The AI agent calls the ListUsers HTTP tool to fetch all users, then delivers its response. Tests the full AHSP tool-call lifecycle: agent job round 1 (tool activation) → ListUsers job completes → agent job round 2 (final response).",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "variables": {
            "inputText": "List all available users for me."
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": {
            "jobType": "io.camunda.agenticai:aiagent-job-worker:1"
          },
          "variables": {
            "agent": {
              "context": {
                "state": "WAITING_FOR_TOOL_CALL_RESULTS",
                "metrics": {
                  "modelCalls": 1,
                  "tokenUsage": {"inputTokenCount": 500, "outputTokenCount": 60}
                },
                "conversation": {
                  "type": "in-process",
                  "messages": [
                    {
                      "role": "user",
                      "content": [{"type": "text", "text": "List all available users for me."}]
                    },
                    {
                      "role": "assistant",
                      "content": [
                        {"type": "tool_use", "id": "tool_001", "name": "ListUsers", "input": {}}
                      ]
                    }
                  ]
                }
              }
            }
          },
          "completionConditionFulfilled": false,
          "activateElements": [
            {
              "elementId": "ListUsers",
              "variables": {
                "toolCall": {
                  "_meta": {"id": "tool_001", "name": "ListUsers"}
                }
              }
            }
          ]
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": {
            "elementId": "ListUsers"
          },
          "variables": {
            "toolCallResult": [
              {"id": 1, "name": "Leanne Graham", "username": "Bret"},
              {"id": 2, "name": "Ervin Howell", "username": "Antonette"},
              {"id": 3, "name": "Clementine Bauch", "username": "Samantha"}
            ]
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": {
            "jobType": "io.camunda.agenticai:aiagent-job-worker:1"
          },
          "variables": {
            "agent": {
              "context": {
                "state": "READY",
                "metrics": {
                  "modelCalls": 2,
                  "tokenUsage": {"inputTokenCount": 900, "outputTokenCount": 120}
                },
                "conversation": {
                  "type": "in-process",
                  "messages": [
                    {
                      "role": "user",
                      "content": [{"type": "text", "text": "List all available users for me."}]
                    },
                    {
                      "role": "assistant",
                      "content": [{"type": "tool_use", "id": "tool_001", "name": "ListUsers", "input": {}}]
                    },
                    {
                      "role": "tool",
                      "content": [{"type": "tool_result", "tool_use_id": "tool_001", "content": "[{\"id\":1,\"name\":\"Leanne Graham\",\"username\":\"Bret\"},{\"id\":2,\"name\":\"Ervin Howell\",\"username\":\"Antonette\"},{\"id\":3,\"name\":\"Clementine Bauch\",\"username\":\"Samantha\"}]"}]
                    },
                    {
                      "role": "assistant",
                      "content": [{"type": "text", "text": "Here are 3 available users: Leanne Graham (Bret), Ervin Howell (Antonette), Clementine Bauch (Samantha)."}]
                    }
                  ]
                }
              },
              "responseText": "Here are 3 available users: Leanne Graham (Bret), Ervin Howell (Antonette), Clementine Bauch (Samantha)."
            }
          },
          "completionConditionFulfilled": true
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "elementSelectors": [
            {"elementId": "User_Feedback"}
          ],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "User_Feedback"
          },
          "variables": {
            "userSatisfied": true
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "Search_Recipe tool — agent searches for a recipe",
      "description": "The AI agent calls the Search_Recipe HTTP tool with a dynamic search query, receives recipe results, then responds. Tests the fromAi() searchQuery expression and recipe result mapping.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "ai-agent-chat-with-tools"
          },
          "variables": {
            "inputText": "Find me a pasta carbonara recipe."
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": {
            "jobType": "io.camunda.agenticai:aiagent-job-worker:1"
          },
          "variables": {
            "agent": {
              "context": {
                "state": "WAITING_FOR_TOOL_CALL_RESULTS",
                "metrics": {
                  "modelCalls": 1,
                  "tokenUsage": {"inputTokenCount": 460, "outputTokenCount": 58}
                },
                "conversation": {
                  "type": "in-process",
                  "messages": [
                    {
                      "role": "user",
                      "content": [{"type": "text", "text": "Find me a pasta carbonara recipe."}]
                    },
                    {
                      "role": "assistant",
                      "content": [
                        {"type": "tool_use", "id": "tool_003", "name": "Search_Recipe", "input": {"searchQuery": "pasta carbonara"}}
                      ]
                    }
                  ]
                }
              }
            }
