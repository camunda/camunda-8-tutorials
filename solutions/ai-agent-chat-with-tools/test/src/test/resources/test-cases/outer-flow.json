        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": {
            "jobType": "io.camunda.agenticai:aiagent-job-worker:1"
          },
          "variables": {
            "agent": {
              "context": {
                "state": "READY",
                "metrics": {
                  "modelCalls": 2,
                  "tokenUsage": {"inputTokenCount": 900, "outputTokenCount": 150}
                },
                "conversation": {
                  "type": "in-process",
                  "messages": [
                    {
                      "role": "user",
                      "content": [{"type": "text", "text": "Please also show me the email of each user."}]
                    },
                    {
                      "role": "assistant",
                      "content": [{"type": "text", "text": "Here are the users with their email addresses."}]
                    }
                  ]
                }
              },
              "responseText": "Here are the users with their email addresses."
